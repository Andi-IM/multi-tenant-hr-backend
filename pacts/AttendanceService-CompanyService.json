{
  "consumer": {
    "name": "AttendanceService"
  },
  "interactions": [
    {
      "description": "a request for employee status",
      "providerStates": [
        {
          "name": "an active employee exists"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer fake-token",
          "X-Company-ID": "comp_abc"
        },
        "method": "GET",
        "path": "/api/v1/internal/employees/emp_123/status"
      },
      "response": {
        "body": {
          "data": {
            "employmentStatus": "ACTIVE",
            "timezone": "Asia/Jakarta",
            "workSchedule": {
              "endTime": "17:00",
              "startTime": "09:00",
              "workingDays": ["Monday"]
            }
          },
          "status": "success"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.data.timezone": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.workSchedule.endTime": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.workSchedule.startTime": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.workSchedule.workingDays": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "CompanyService"
  }
}
