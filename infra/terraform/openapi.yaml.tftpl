        "200":
          description: "OK"
    delete:
      operationId: "company_a_delete"
      parameters:
        - $ref: "#/parameters/relPath"
      x-google-backend:
        address: "${company_a_url}"
        path_translation: APPEND_PATH_TO_ADDRESS
      responses:
        "200":
          description: "OK"
    patch:
