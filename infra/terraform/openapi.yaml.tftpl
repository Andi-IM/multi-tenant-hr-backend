    patch:
      operationId: "company_b_patch"
      parameters:
        - $ref: "#/parameters/relPath"
      x-google-backend:
        address: "${company_b_url}"
        path_translation: APPEND_PATH_TO_ADDRESS
      responses:
        "200":
          description: "OK"

  # Attendance Routing
  /attendance/{relPath=**}:
    get:
      operationId: "attendance_get"
      parameters:
        - $ref: "#/parameters/relPath"
      x-google-backend:
        address: "${attendance_url}"
