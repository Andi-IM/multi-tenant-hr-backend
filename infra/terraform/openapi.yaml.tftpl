swagger: "2.0"
info:
  title: "multi-tenant-hr-backend"
  version: "1.0.0"
schemes:
  - "https"
produces:
  - "application/json"

# Standard OpenAPI Parameter Definition
parameters:
  relPath:
    name: "relPath"
    in: "path"
    required: true
    type: "string"

paths:
  /:
    get:
      operationId: "root"
      x-google-backend:
        address: "${company_a_url}"
      responses:
        "200":
          description: "OK"

  # Company A Routing
  /company-a/{relPath=**}:
    get:
      operationId: "company_a_get"
      parameters:
        - $ref: "#/parameters/relPath"
      x-google-backend:
        address: "${company_a_url}"
        path_translation: APPEND_PATH_TO_ADDRESS
      responses:
        "200":
          description: "OK"
    post:
      operationId: "company_a_post"
      parameters:
        - $ref: "#/parameters/relPath"
      x-google-backend:
        address: "${company_a_url}"
        path_translation: APPEND_PATH_TO_ADDRESS
